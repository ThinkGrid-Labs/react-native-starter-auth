{
  "extends": "@tsconfig/react-native/tsconfig.json",
  "compilerOptions": {
    "types": ["react-native", "jest", "node"],
    "typeRoots": [
      "@types",
      "./node_modules/@types"
    ],
    "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"],
      "types/*": ["./@types/*"]
    }
  },
  "include": ["src/**/*", "@types/**/*"],
  "exclude": ["node_modules", "example", "coverage", "**/*.test.ts", "**/*.test.tsx"]
}
